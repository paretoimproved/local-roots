# E2E_STRIPE_PK=pk_test_...

# Optional — set to run magic-link DB verification test
# E2E_DATABASE_URL=postgres://localroots:localroots@localhost:5432/localroots?sslmode=disable

# Optional — set to true if a test seller has completed Stripe Connect onboarding
# E2E_STRIPE_CONNECT_READY=true
